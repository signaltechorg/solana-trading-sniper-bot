RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=
RPC_WEBSOCKET_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=

# Redis (required for event queue)
REDIS_URL=redis://127.0.0.1:6379
REDIS_POOL_QUEUE_KEY=sniper:pool-events
REDIS_PROCESSED_PREFIX=sniper:processed
REDIS_PROCESSED_TTL_SEC=86400

# Set true to validate only, no on-chain txs
DRY_RUN=false

# Use in-memory Redis for npm run validate (no Redis server required)
# REDIS_MEMORY=true
BUY_AMOUNT=0.00001
WSOL_AMOUNT=0.00001
DELAY=2000
MIN_LIQUIDITY_SOL=100
MAX_DEV_WALLET_SUPPLY_PCT=20
MAX_SELL_TAX_PCT=10
REQUIRE_REVOKED_UPGRADE_AUTHORITY=true

TP_LEVELS_PCT1=25
TP_LEVELS_PCT2=50
TP_LEVELS_PCT3=100
TP_SIZE_PCT1=0.3
TP_SIZE_PCT2=0.4
TP_SIZE_PCT3=0.3

TRAIL_DISTANCE_PCT=10
HARD_STOP_LOSS_PCT=-25
JITO_FEE=0.00001


PRIVATE_KEY=